#4 Create a module calculator.py that contains: A constant PI = 3.14 A function square(n) to calculate square of a number=======================
# calculator.py

PI = 3.14

def square(n):
    return n * n

def circle_area(radius):
    return PI * radius * radius

def rectangle_area(length, width):
    return length * width

def triangle_area(base, height):
    return 0.5 * base * height
#5 Write a Python program that uses the math module to: Greet the user before calculation Find the square root of a number Find the power of a number Display the value of π Greeting the user after calculation
# main.py

import math
import greetings
import calculator

# Greeting before calculation
name = input("Enter your name: ")
greetings.say_hello(name)

# Square root
num = int(input("Enter a number for square root: "))
print("Square root:", math.sqrt(num))

# Power
base = int(input("Enter base: "))
power = int(input("Enter power: "))
print("Power:", math.pow(base, power))

# Value of PI
print("Value of PI:", math.pi)

# Using custom module
n = int(input("Enter number to find square: "))
print("Square using calculator module:", calculator.square(n))

# Goodbye message
greetings.say_goodbye(name)
