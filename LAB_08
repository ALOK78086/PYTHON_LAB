# 1 Create a module named mymath.py that contains two functions: add(a, b) to return the sum of two numbers subtract(a, b) to return the difference=======
# mymath.py

def add(a, b):
    return a + b

def subtract(a, b):
    return a - b

def multiply(a, b):
    return a * b

def divide(a, b):
    if b == 0:
        raise ValueError("Denominator cannot be zero.")
    return a / b
#2 Create a module named area.py that contains functions to calculate: Area of a circle Area of a rectangle==========================================
# area.py

def circle_area(radius):
    return 3.14 * radius * radius

def rectangle_area(length, width):
    return length * width

def triangle_area(base, height):
    return 0.5 * base * height

